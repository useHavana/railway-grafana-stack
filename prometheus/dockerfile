ARG VERSION=v3.2.1

FROM prom/prometheus:${VERSION}

# Copy config to both custom and default paths (Railway may override CMD)
COPY prom.yml /etc/prometheus/prom.yml
COPY prom.yml /etc/prometheus/prometheus.yml

# Command to run Prometheus
CMD ["--config.file=/etc/prometheus/prom.yml", "--storage.tsdb.path=/prometheus", "--web.enable-remote-write-receiver", "--storage.tsdb.retention.time=30d"]
